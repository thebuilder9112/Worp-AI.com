{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores user settings and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "theme": { "type": "string" },
        "accentColor": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "chatSession": {
      "title": "Chat Session",
      "description": "A single conversation session.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "mode": { "type": "string", "enum": ["standard", "code", "art", "research"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "createdAt"]
    },
    "chatMessage": {
      "title": "Chat Message",
      "description": "A single message within a session.",
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["role", "text", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "User specific settings and profile data."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "chatSession",
      "description": "List of user chat sessions."
    },
    "/users/{userId}/sessions/{sessionId}/messages/{messageId}": {
      "schema": "chatMessage",
      "description": "Persistent message log for the session."
    }
  }
}
